# ============================================================
# PUBLIC DOMAIN CONFIGURATION
# Fill these AFTER running `terraform apply` (see infra/README)
# ============================================================

# CloudFront domain for LobeChat (output: lobechat_domain)
LOBECHAT_DOMAIN=xxxx.cloudfront.net

# CloudFront domain for Casdoor SSO (output: casdoor_domain)
CASDOOR_DOMAIN=yyyy.cloudfront.net

# Shared secret injected by CloudFront as X-CloudFront-Secret header.
# Must match the value set in Terraform variable cf_secret.
# Generate with: openssl rand -hex 32
CF_SECRET=change-me-cloudfront-secret

# ============================================================
# SECRETS — generate with: openssl rand -base64 32
# ============================================================
KEY_VAULTS_SECRET=change-me-key-vaults-secret-32b
NEXT_AUTH_SECRET=change-me-nextauth-secret-32b

# ============================================================
# CASDOOR SSO — from config/init_data.json applications[0]
# ============================================================
AUTH_CASDOOR_ID=a387a4892ee19b1a2249
AUTH_CASDOOR_SECRET=dbf205949d704de81b0b5b3603174e23fbecc354

# ============================================================
# POSTGRESQL
# ============================================================
POSTGRES_PASSWORD=change-me-postgres

# ============================================================
# MINIO S3
# ============================================================
S3_BUCKET=lobe
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-minio

# ============================================================
# LLM / EMBEDDINGS
# ============================================================
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-api-key

# ============================================================
# PORTS (internal — not directly exposed to the internet)
# ============================================================
CASDOOR_PORT=47002
POSTGRES_PORT=47003
MINIO_PORT=47005
MINIO_CONSOLE_PORT=47006
VLLM_PORT=47007
MCPHUB_PORT=47008
QDRANT_PORT=47009
QDRANT_GRPC_PORT=47010

# ============================================================
# MCPHUB / SSH
# ============================================================
MCPHUB_ADMIN_USER=admin
MCPHUB_ADMIN_PASSWORD=change-me-mcphub
SSH_HOST=your-ssh-host
SSH_PORT=22
SSH_USERNAME=your-ssh-user
SSH_ALLOWED_COMMANDS=ls,cat,head,tail,grep,find,ps,df,du,uptime,whoami,pwd,echo
SSH_ALLOWED_PATHS=/home,/tmp,/var/log
SSH_COMMANDS_BLACKLIST=rm,mv,dd,mkfs,fdisk,format,shutdown,reboot
SSH_ARGUMENTS_BLACKLIST=-rf,-fr,--force

# ============================================================
# AWS
# ============================================================
AWS_REGION=eu-west-1
AWS_DEFAULT_REGION=eu-west-1

# ============================================================
# vLLM (only needed with --profile gpu)
# ============================================================
VLLM_MODEL_ID=oriolrius/myemoji-gemma-3-270m-it
HF_TOKEN=hf_your-huggingface-token
